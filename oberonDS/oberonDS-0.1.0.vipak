[BUILD]
run = "voc -s src/DynamicArray.Mod
voc -s src/HashMap.Mod
voc -s src/Map.Mod
voc -m test/DynamicArrayTest.Mod
voc -m test/HashMapTest.Mod
voc -m test/MapTest.Mod"
